# AgentFactory TUI — Environment Variables
# Copy to .env.local and fill in your values.
# .env.local is gitignored and will be loaded automatically.

# ── Coordinator ──────────────────────────────────────────────
# URL of the AgentFactory coordinator API
WORKER_API_URL=http://localhost:3000

# API key for authenticating with the coordinator
WORKER_API_KEY=

# ── Worker / Fleet ───────────────────────────────────────────
# Number of worker processes (default: CPU cores / 2)
# WORKER_FLEET_SIZE=4

# Max concurrent agents per worker (default: 3)
# WORKER_CAPACITY=3

# Comma-separated project names this worker accepts
# WORKER_PROJECTS=

# ── Linear ───────────────────────────────────────────────────
# Linear API key (required for issue tracking commands)
LINEAR_API_KEY=

# Alternative: Linear OAuth access token
# LINEAR_ACCESS_TOKEN=

# ── Governor ─────────────────────────────────────────────────
# Redis connection URL (required for governor, agent, queue commands)
# REDIS_URL=redis://localhost:6379

# Comma-separated project names for governor to manage
# GOVERNOR_PROJECTS=

# ── Code Intelligence (optional) ─────────────────────────────
# Voyage AI API key for semantic vector embeddings
# VOYAGE_AI_API_KEY=

# Cohere API key for cross-encoder reranking
# COHERE_API_KEY=

# ── Misc ─────────────────────────────────────────────────────
# Base directory for agent session logs (default: .agent-logs)
# AGENT_LOGS_DIR=.agent-logs

# Disable automatic update checks (set to 1 or true)
# AF_NO_UPDATE_CHECK=
