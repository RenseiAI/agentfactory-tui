{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|clear|resume",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/scripts/refresh-worktree.sh",
            "timeout": 180
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "if echo \"$CLAUDE_TOOL_INPUT\" | grep -qE 'git commit|gh pr create'; then \"$CLAUDE_PROJECT_DIR\"/scripts/check-oss-boundary.sh --all; fi",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
